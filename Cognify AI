<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognify AI - World's Smartest AI Tutor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body {
            background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
            color: #e2e8f0;
            overflow-x: hidden;
        }
        .glass {
            backdrop-filter: blur(20px);
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
        .float { animation: float 4s ease-in-out infinite; }
        .pulse-glow { animation: pulse 2s infinite; }
        @keyframes pulse { 0%,100%{box-shadow:0 0 20px rgba(99,102,241,0.3);} 50%{box-shadow:0 0 40px rgba(99,102,241,0.6);} }
    </style>
</head>
<body>
    <!-- Video Hero Background -->
    <div class="fixed inset-0 z-0 overflow-hidden">
        <video autoplay muted loop class="w-full h-full object-cover opacity-20">
            <source src="data:video/mp4;base64,//data video placeholder - professional particle animation" type="video/mp4">
        </video>
    </div>

    <!-- Navigation -->
    <nav class="glass fixed top-0 w-full z-50 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="text-3xl font-black gradient-text">🤖 Cognify AI</div>
            <div class="flex gap-4 items-center">
                <button onclick="toggleSettings()" class="glass p-3 rounded-xl hover:scale-110 transition-all">⚙️</button>
                <button class="bg-gradient-to-r from-blue-500 to-purple-600 px-8 py-3 rounded-2xl font-bold hover:scale-105">Install App</button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center pt-24 px-6 relative z-10">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
            <!-- Hero Content -->
            <div class="space-y-8">
                <div class="inline-block">
                    <span class="px-4 py-2 bg-blue-500/20 rounded-full text-sm font-semibold">World's #1 AI Tutor</span>
                </div>
                <h1 class="text-6xl lg:text-7xl font-black leading-tight">
                    <span>Your Personal</span>
                    <span class="gradient-text">AI Tutor</span>
                    <span>Beats Human Teachers</span>
                </h1>
                <p class="text-xl text-gray-300 max-w-lg">Upload book photo → Instant video explanation. Voice chat 100+ languages. Monthly tests. JEE/NEET/SAT leaderboards.</p>
                
                <div class="flex flex-wrap gap-4">
                    <button onclick="scrollToAI()" class="bg-gradient-to-r from-emerald-500 to-teal-600 px-12 py-5 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-3xl hover:scale-105 transition-all">🎙️ Talk Now</button>
                    <button class="glass px-12 py-5 rounded-2xl font-bold border-2 border-white/20 hover:border-white/40">📸 Camera</button>
                </div>
                
                <div class="flex gap-8 text-sm text-gray-400">
                    <div>50K+ Students</div>
                    <div>•</div>
                    <div>98.7% Success</div>
                    <div>•</div>
                    <div>JEE AIR #1</div>
                </div>
            </div>

            <!-- Animated AI Demo -->
            <div class="relative group">
                <div class="glass p-8 rounded-3xl float pulse-glow">
                    <div class="bg-gradient-to-br from-gray-900/80 to-black/50 rounded-2xl p-8 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-emerald-500/10 animate-pulse"></div>
                        
                        <!-- AI Chat Demo -->
                        <div class="relative z-10 space-y-4 h-96 overflow-hidden">
                            <div class="bg-blue-500/20 backdrop-blur-sm p-4 rounded-2xl text-sm animate-slide-in">
                                <strong>📚 Student:</strong> Solve ∫x²e^x dx (JEE Advanced)
                            </div>
                            <div class="bg-white/10 backdrop-blur-sm p-4 rounded-2xl text-sm animate-slide-in delay-200">
                                <strong>🤖 AI Tutor:</strong> Integration by parts! Let u=x², dv=e^x dx... <span class="text-emerald-400">✨</span>
                            </div>
                            <div class="flex gap-2 mt-6">
                                <input class="flex-1 bg-gray-800/50 border border-white/20 rounded-xl px-4 py-2 text-white placeholder-gray-400" placeholder="Ask JEE Math...">
                                <div class="w-10 h-10 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center text-xl">➤</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Dashboard -->
    <section class="py-24 px-6 relative z-10">
        <div class="max-w-7xl mx-auto">
            <!-- Settings Context -->
            <div class="glass p-6 rounded-3xl mb-12">
                <div class="flex flex-wrap gap-4 text-lg font-semibold">
                    <span class="bg-blue-500/20 px-4 py-2 rounded-xl">Class 12</span>
                    <span class="bg-purple-500/20 px-4 py-2 rounded-xl">JEE Advanced</span>
                    <span class="bg-emerald-500/20 px-4 py-2 rounded-xl">Mathematics</span>
                    <span class="bg-indigo-500/20 px-4 py-2 rounded-xl">🇮🇳 Hindi</span>
                </div>
            </div>

            <div class="grid lg:grid-cols-2 gap-12">
                <!-- Smart AI Chat -->
                <div class="glass p-10 rounded-3xl">
                    <h2 class="text-4xl font-black mb-8 gradient-text flex items-center gap-3">
                        <span>🧠</span> Smart Tutor
                    </h2>
                    <div id="chat-container" class="h-96 bg-gradient-to-b from-gray-900/50 to-black/30 rounded-3xl p-8 mb-8 overflow-y-auto space-y-4">
                        <div class="bg-gradient-to-r from-blue-500/20 to-blue-600/20 backdrop-blur-sm p-6 rounded-2xl max-w-md ml-auto animate-pulse">
                            <strong>You:</strong> Explain vectors for JEE
                        </div>
                        <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl max-w-lg animate-pulse delay-500">
                            <strong>🤖 AI Tutor:</strong> Vectors in 3D - Position vector r = xi + yj + zk. Dot product a·b = |a||b|cosθ... <span class="text-emerald-400">Watch video ➤</span>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <input id="message-input" class="flex-1 bg-gray-900/50 border border-white/20 rounded-2xl px-6 py-4 text-lg placeholder-gray-400 focus:outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-400/50" placeholder="Ask about JEE Math, NEET Biology, AI courses...">
                        <button onclick="sendMessage()" class="bg-gradient-to-r from-emerald-500 to-teal-600 px-16 py-4 rounded-2xl font-bold text-lg hover:scale-105 shadow-2xl hover:shadow-emerald-500/25 transition-all">Send</button>
                        <button onclick="startVoice()" class="glass w-16 h-16 rounded-2xl flex items-center justify-center text-2xl hover:scale-110 transition-all">🎤</button>
                    </div>
                </div>

                <!-- Camera + Quick Actions -->
                <div class="space-y-8">
                    <!-- Smart Camera -->
                    <div class="glass p-10 rounded-3xl">
                        <h3 class="text-3xl font-bold mb-8 gradient-text flex items-center gap-3">
                            <span>📸</span> Smart Camera
                        </h3>
                        <div class="space-y-6">
                            <div class="text-center py-12 border-2 border-dashed border-white/30 rounded-3xl hover:border-emerald-400 hover:bg-white/5 transition-all cursor-pointer group" onclick="openCamera()">
                                <div class="text-5xl mb-4 group-hover:scale-110 transition-all">📷</div>
                                <div class="text-xl font-semibold mb-2">Capture Book Page</div>
                                <div class="text-gray-400">Click or drag JEE problem</div>
                            </div>
                            <label class="block w-full bg-gradient-to-r from-blue-500/90 to-blue-600 p-8 rounded-3xl text-center font-bold cursor-pointer hover:scale-105 transition-all shadow-2xl hover:shadow-blue-500/25">
                                📁 Upload Photo
                                <input type="file" id="photo-upload" accept="image/*" class="hidden">
                            </label>
                            <div id="photo-result" class="hidden p-6 bg-emerald-500/20 backdrop-blur-sm rounded-2xl border border-emerald-400/50">
                                <div class="text-2xl mb-4">✅ Analysis Complete</div>
                                <div>Extracted 3 JEE problems • Video solutions ready</div>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="grid grid-cols-2 gap-4">
                        <button class="glass p-8 rounded-2xl hover:scale-105 transition-all flex flex-col items-center gap-3">
                            <div class="text-3xl">🏆</div>
                            <div class="font-bold">Join League</div>
                        </button>
                        <button class="bg-gradient-to-r from-purple-500 to-pink-600 p-8 rounded-2xl font-bold hover:scale-105 shadow-2xl hover:shadow-purple-500/25 transition-all flex flex-col items-center gap-3">
                            📊
                            <div>Mock Test</div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Live Leaderboard -->
    <section class="py-24 px-6 relative z-10">
        <div class="max-w-7xl mx-auto">
            <div class="glass p-12 rounded-4xl text-center mb-16">
                <h2 class="text-6xl font-black mb-8 gradient-text">🏆 Live Exam League</h2>
                <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-16">Compete globally • Real-time rankings • JEE/NEET/SAT</p>
                
                <div class="grid md:grid-cols-3 gap-12 max-w-4xl mx-auto">
                    <!-- Gold -->
                    <div class="group hover:scale-105 transition-all">
                        <div class="w-28 h-28 bg-gradient-to-r from-yellow-400 to-orange-400 rounded-full mx-auto mb-6 shadow-2xl group-hover:animate-bounce">🥇</div>
                        <div class="text-4xl font-black text-transparent bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text mb-2">Rahul S.</div>
                        <div class="text-3xl font-bold text-yellow-400 mb-2">8,247 pts</div>
                        <div class="text-sm text-gray-400">JEE AIR #1</div>
                    </div>
                    
                    <!-- Silver -->
                    <div class="group hover:scale-105 transition-all">
                        <div class="w-28 h-28 bg-gradient-to-r from-gray-300 to-silver rounded-full mx-auto mb-6 shadow-2xl group-hover:animate-bounce">🥈</div>
                        <div class="text-4xl font-black text-transparent bg-gradient-to-r from-gray-300 to-white bg-clip-text mb-2">Priya R.</div>
                        <div class="text-3xl font-bold text-gray-300 mb-2">8,120 pts</div>
                        <div class="text-sm text-gray-400">NEET Rank #2</div>
                    </div>
                    
                    <!-- Bronze -->
                    <div class="group hover:scale-105 transition-all">
                        <div class="w-28 h-28 bg-gradient-to-r from-orange-500 to-yellow-500 rounded-full mx-auto mb-6 shadow-2xl group-hover:animate-bounce">🥉</div>
                        <div class="text-4xl font-black text-transparent bg-gradient-to-r from-orange-500 to-yellow-400 bg-clip-text mb-2">Arjun K.</div>
                        <div class="text-3xl font-bold text-yellow-400 mb-2">7,980 pts</div>
                        <div class="text-sm text-gray-400">SAT 1590/1600</div>
                    </div>
                </div>
                
                <button class="mt-16 bg-gradient-to-r from-emerald-500 to-teal-600 px-20 py-6 rounded-3xl font-black text-2xl hover:scale-105 shadow-2xl hover:shadow-emerald-500/50 transition-all">⚡ Compete Now</button>
            </div>
        </div>
    </section>

    <!-- Settings Panel -->
    <div id="settings-panel" class="glass fixed top-24 right-6 z-50 p-8 rounded-3xl shadow-2xl w-96 max-h-[80vh] overflow-y-auto hidden">
        <h3 class="text-3xl font-bold mb-8 gradient-text">⚙️ Smart Settings</h3>
        
        <div class="space-y-6">
            <div>
                <label class="block text-lg font-semibold mb-3">Class/Level</label>
                <select class="w-full bg-gray-900/50 border border-white/20 rounded-2xl px-6 py-4 text-white text-lg">
                    <option>Class 12 (JEE)</option>
                    <option>Class 11</option>
                    <option>Class 10 (CBSE)</option>
                    <option>B.Tech CS</option>
                </select>
            </div>
            
            <div>
                <label class="block text-lg font-semibold mb-3">Exam</label>
                <select class="w-full bg-gray-900/50 border border-white/20 rounded-2xl px-6 py-4 text-white text-lg">
                    <option>JEE Advanced</option>
                    <option>JEE Main</option>
                    <option>NEET</option>
                    <option>SAT</option>
                </select>
            </div>
            
            <div>
                <label class="block text-lg font-semibold mb-3">Subject</label>
                <select class="w-full bg-gray-900/50 border border-white/20 rounded-2xl px-6 py-4 text-white text-lg">
                    <option>Mathematics</option>
                    <option>Physics</option>
                    <option>AI/ML</option>
                    <option>Music Theory</option>
                </select>
            </div>
            
            <div>
                <label class="block text-lg font-semibold mb-3">Language</label>
                <select class="w-full bg-gray-900/50 border border-white/20 rounded-2xl px-6 py-4 text-white text-lg">
                    <option>🇮🇳 Hindi</option>
                    <option>🇺🇸 English</option>
                    <option>🇧🇩 Bengali</option>
                    <option>🇪🇸 Spanish</option>
                </select>
            </div>
        </div>
        
        <button onclick="toggleSettings()" class="mt-8 w-full bg-gradient-to-r from-emerald-500 to-teal-600 px-8 py-5 rounded-2xl font-bold text-xl hover:scale-105 shadow-2xl hover:shadow-emerald-500/25 transition-all">Apply Settings</button>
    </div>

    <script>
        // Professional animations
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate-slide-in');
                }
            });
        });

        // Chat functionality
        function sendMessage() {
            const input = document.getElementById('message-input');
            const container = document.getElementById('chat-container');
            const message = input.value.trim();
            
            if (!message) return;
            
            // Add user message
            const userMsg = document.createElement('div');
            userMsg.className = 'bg-gradient-to-r from-blue-500/20 to-blue-600/20 backdrop-blur-sm p-6 rounded-2xl max-w-md ml-auto animate-pulse';
            userMsg.innerHTML = `<strong>You:</strong> ${message}`;
            container.appendChild(userMsg);
            
            // Simulate typing
            input.value = '';
            container.scrollTop = container.scrollHeight;
            
            // AI response
            setTimeout(() => {
                const aiMsg = document.createElement('div');
                aiMsg.className = 'bg-white/10 backdrop-blur-sm p-6 rounded-2xl max-w-lg animate-pulse';
                aiMsg.innerHTML = `
                    <strong>🤖 AI Tutor:</strong> Perfect JEE Advanced question! Let me solve step-by-step:<br>
                    <span class="ml-4 mt-2 block text-emerald-400">• Integration by parts: u = x², dv = eˣdx<br>
                    • du = 2x dx, v = eˣ<br>
                    • ∫x²eˣdx = x²eˣ - 2∫xeˣdx ✨</span>
                `;
                container.appendChild(aiMsg);
                container.scrollTop = container.scrollHeight;
            }, 1200);
        }

        function toggleSettings() {
            document.getElementById('settings-panel').classList.toggle('hidden');
        }

        function scrollToAI() {
            document.querySelector('.glass').scrollIntoView({ behavior: 'smooth' });
        }

        function startVoice() {
            if ('webkitSpeechRecognition' in window) {
                const recognition = new webkitSpeechRecognition();
                recognition.onresult = (e) => {
                    document.getElementById('message-input').value = e.results[0][0].transcript;
                    sendMessage();
                };
                recognition.start();
            }
        }

        function openCamera() {
            document.getElementById('photo-upload').click();
        }

        // Photo upload
        document.getElementById('photo-upload').addEventListener('change', (e) => {
            if (e.target.files[0]) {
                document.getElementById('photo-result').classList.remove('hidden');
            }
        });

        // Enter key
        document.getElementById('message-input').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Animate on scroll
        document.querySelectorAll('.glass').forEach(el => observer.observe(el));
    </script>
</body>
</html>
