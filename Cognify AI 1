<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognify AI - World's Smartest AI Tutor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { 
            background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
            color: #e2e8f0; 
            overflow-x: hidden;
        }
        .glass {
            backdrop-filter: blur(20px);
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
        .float { animation: float 4s ease-in-out infinite; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .slide-in { animation: slideIn 0.8s ease-out forwards; }
        .animate-pulse-slow { animation: pulse 3s infinite; }
    </style>
</head>
<body class="min-h-screen pt-20 px-4 md:px-8">
    
    <!-- Navigation -->
    <nav class="glass fixed top-0 left-0 right-0 z-50 px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-3xl font-black gradient-text cursor-pointer" onclick="scrollToTop()">🤖 Cognify AI</h1>
            <div class="flex items-center gap-4">
                <button onclick="toggleSettings()" class="p-3 rounded-2xl hover:bg-white/10 transition-all duration-300">⚙️</button>
                <button onclick="installPWA()" class="bg-gradient-to-r from-emerald-500 to-teal-600 px-6 py-2 rounded-xl font-semibold hover:scale-105 transition-all duration-300">Install App</button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center py-24">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center px-4">
            <!-- Hero Text -->
            <div class="space-y-8 slide-in">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-2xl">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                    <span class="font-semibold text-lg">50K+ Students • JEE #1</span>
                </div>
                <h2 class="text-5xl md:text-7xl font-black leading-tight">
                    <span>Your Personal</span>
                    <div class="gradient-text text-6xl md:text-8xl font-black">AI Tutor</div>
                    <span class="text-3xl md:text-4xl text-gray-300">Beats 99% Human Teachers</span>
                </h2>
                <p class="text-xl text-gray-300 max-w-lg leading-relaxed">Upload photo → Instant video explanation. Voice chat 100+ languages. Live leaderboards. JEE/NEET/SAT ready.</p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <button onclick="scrollToChat()" class="bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 px-12 py-6 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-emerald-500/50 transform hover:-translate-y-1 transition-all duration-300">🎙️ Start Chatting</button>
                    <button onclick="openCamera()" class="glass px-12 py-6 rounded-2xl font-bold border-2 border-white/20 hover:border-emerald-400 hover:bg-white/10 transition-all duration-300">📸 Camera</button>
                </div>
            </div>

            <!-- AI Demo -->
            <div class="relative group slide-in animation-delay-200">
                <div class="glass p-8 rounded-3xl float hover:scale-[1.02] transition-all duration-500">
                    <div class="bg-gradient-to-br from-gray-900/90 to-black/50 rounded-2xl p-8 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/5 via-blue-500/5 to-purple-500/5 animate-pulse-slow"></div>
                        <div id="demo-chat" class="relative z-10 h-80 overflow-y-auto space-y-4 pr-2">
                            <div class="bg-blue-500/20 backdrop-blur-sm p-4 rounded-2xl max-w-md ml-auto">
                                <strong>📚 You:</strong> Solve this JEE integral...
                            </div>
                            <div class="bg-white/10 backdrop-blur-sm p-4 rounded-2xl max-w-lg">
                                <strong>🤖 AI Tutor:</strong> Perfect question! Using integration by parts:<br>
                                <code class="bg-gray-800 px-2 py-1 rounded text-xs mt-2 block">u = x², dv = eˣdx → du = 2xdx, v = eˣ</code>
                                <span class="text-emerald-400 ml-4 inline-block mt-2">✨ Watch video explanation</span>
                            </div>
                        </div>
                        <div class="absolute bottom-4 left-4 right-4 flex gap-2">
                            <input class="flex-1 bg-gray-900/70 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-gray-400 text-sm" placeholder="Type your doubt..." readonly>
                            <button class="bg-emerald-500 hover:bg-emerald-600 w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-sm">➤</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Dashboard -->
    <section class="py-24 px-4 max-w-6xl mx-auto">
        <!-- Context Bar -->
        <div class="glass p-6 rounded-3xl mb-12">
            <div class="flex flex-wrap gap-4 text-lg font-semibold">
                <span class="bg-emerald-500/20 px-6 py-3 rounded-2xl">Class 12</span>
                <span class="bg-purple-500/20 px-6 py-3 rounded-2xl">JEE Advanced</span>
                <span class="bg-blue-500/20 px-6 py-3 rounded-2xl">Mathematics</span>
                <span class="bg-indigo-500/20 px-6 py-3 rounded-2xl">🇮🇳 Hindi</span>
            </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-12">
            <!-- AI Chat -->
            <div class="glass p-10 rounded-3xl">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center text-2xl font-bold">🧠</div>
                    <div>
                        <h2 class="text-4xl font-black gradient-text">Smart AI Tutor</h2>
                        <div class="w-24 h-1 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-full mt-2"></div>
                    </div>
                </div>
                
                <div id="chat-messages" class="h-96 bg-gradient-to-b from-gray-900/50 to-black/30 rounded-3xl p-8 mb-8 overflow-y-auto space-y-4 scrollbar-thin scrollbar-thumb-gray-700 scrollbar-track-gray-900">
                    <!-- Messages will be added here -->
                </div>
                
                <div class="flex gap-4">
                    <input id="chat-input" class="flex-1 bg-gray-900/70 border-2 border-gray-700 hover:border-gray-600 focus:border-emerald-400 focus:ring-4 focus:ring-emerald-400/20 rounded-2xl px-6 py-4 text-lg placeholder-gray-400 transition-all duration-300" placeholder="Ask about JEE Math, vectors, integration...">
                    <button onclick="sendMessage()" class="bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 px-16 py-4 rounded-2xl font-bold text-lg shadow-xl hover:shadow-emerald-500/30 transform hover:-translate-y-0.5 transition-all duration-300 min-w-[100px]">Send</button>
                    <button onclick="toggleVoice()" id="voice-btn" class="glass p-4 rounded-2xl hover:bg-white/10 transition-all duration-300 w-16 h-16 flex items-center justify-center text-2xl">🎤</button>
                </div>
            </div>

            <!-- Camera & Quick Actions -->
            <div class="space-y-8">
                <!-- Smart Camera -->
                <div class="glass p-10 rounded-3xl">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center text-2xl font-bold">📸</div>
                        <div>
                            <h3 class="text-3xl font-black gradient-text">Smart Camera</h3>
                            <div class="text-sm text-gray-400">Snap book page → Instant analysis</div>
                        </div>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="group cursor-pointer" onclick="simulateCamera()">
                            <div class="border-2 border-dashed border-white/30 hover:border-emerald-400 hover:bg-white/5 rounded-3xl p-12 text-center transition-all duration-300 group-hover:scale-105">
                                <div class="text-5xl mb-4 group-hover:scale-110 transition-all duration-300">📷</div>
                                <div class="text-xl font-bold mb-2">Open Camera</div>
                                <div class="text-gray-400 text-sm">Capture JEE problem instantly</div>
                            </div>
                        </div>
                        
                        <label for="file-upload" class="block w-full bg-gradient-to-r from-blue-500/90 to-blue-600 hover:from-blue-600 hover:to-blue-700 p-8 rounded-3xl text-center font-bold cursor-pointer shadow-2xl hover:shadow-blue-500/30 transition-all duration-300 group">
                            📁 Upload Photo
                            <input type="file" id="file-upload" accept="image/*" class="hidden">
                        </label>
                    </div>
                    
                    <div id="upload-result" class="mt-6 p-6 bg-emerald-500/20 backdrop-blur-sm rounded-2xl border-2 border-emerald-400/50 hidden">
                        <div class="text-2xl font-bold mb-4 flex items-center gap-2">
                            ✅ Analysis Complete
                            <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                        </div>
                        <div class="space-y-2 text-sm">
                            <div>✅ Extracted 3 calculus problems</div>
                            <div>✅ Video solutions generated</div>
                            <div>✅ JEE Advanced difficulty matched</div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="grid grid-cols-2 gap-6">
                    <button onclick="joinLeague()" class="glass p-8 rounded-2xl hover:scale-105 hover:bg-white/10 transition-all duration-300 flex flex-col items-center gap-3">
                        <div class="text-4xl">🏆</div>
                        <div class="font-bold text-xl">Join League</div>
                        <div class="text-sm text-gray-400">Compete globally</div>
                    </button>
                    <button onclick="startTest()" class="bg-gradient-to-r from-purple-500 to-pink-600 hover:from-purple-600 hover:to-pink-700 p-8 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-purple-500/30 transform hover:-translate-y-1 transition-all duration-300 flex flex-col items-center gap-3">
                        📊
                        <div>Mock Test</div>
                        <div class="text-sm text-purple-100">10 questions</div>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Leaderboard -->
    <section class="py-24 px-4">
        <div class="max-w-6xl mx-auto">
            <div class="glass p-12 rounded-4xl text-center">
                <h2 class="text-5xl md:text-6xl font-black mb-8 gradient-text">🏆 Live Leaderboard</h2>
                <p class="text-xl text-gray-300 mb-16 max-w-2xl mx-auto">Real-time rankings • JEE/NEET/SAT • Global competition</p>
                
                <div class="grid md:grid-cols-3 gap-12 max-w-4xl mx-auto mb-16">
                    <!-- 1st Place -->
                    <div class="group cursor-pointer" onclick="claimRank(1)">
                        <div class="w-28 h-28 bg-gradient-to-r from-yellow-400 to-orange-400 rounded-full mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-all duration-300 flex items-center justify-center text-3xl font-bold">🥇</div>
                        <div class="text-3xl md:text-4xl font-black bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text text-transparent mb-3 group-hover:scale-110 transition-all duration-300">Rahul S.</div>
                        <div class="text-2xl font-bold text-yellow-400 mb-2">12,847 pts</div>
                        <div class="text-sm text-gray-400 bg-yellow-500/20 px-4 py-2 rounded-xl inline-block">JEE AIR #1</div>
                    </div>

                    <!-- 2nd Place -->
                    <div class="group cursor-pointer" onclick="claimRank(2)">
                        <div class="w-28 h-28 bg-gradient-to-r from-gray-300 to-gray-200 rounded-full mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-all duration-300 flex items-center justify-center text-3xl font-bold">🥈</div>
                        <div class="text-3xl md:text-4xl font-black bg-gradient-to-r from-gray-300 to-white bg-clip-text text-transparent mb-3 group-hover:scale-110 transition-all duration-300">Priya R.</div>
                        <div class="text-2xl font-bold text-gray-300 mb-2">12,320 pts</div>
                        <div class="text-sm text-gray-400 bg-gray-400/20 px-4 py-2 rounded-xl inline-block">NEET Rank #2</div>
                    </div>

                    <!-- 3rd Place -->
                    <div class="group cursor-pointer" onclick="claimRank(3)">
                        <div class="w-28 h-28 bg-gradient-to-r from-orange-500 to-yellow-500 rounded-full mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-all duration-300 flex items-center justify-center text-3xl font-bold">🥉</div>
                        <div class="text-3xl md:text-4xl font-black bg-gradient-to-r from-orange-500 to-yellow-400 bg-clip-text text-transparent mb-3 group-hover:scale-110 transition-all duration-300">Arjun K.</div>
                        <div class="text-2xl font-bold text-yellow-400 mb-2">11,980 pts</div>
                        <div class="text-sm text-gray-400 bg-orange-500/20 px-4 py-2 rounded-xl inline-block">SAT 1590/1600</div>
                    </div>
                </div>
                
                <button onclick="joinLeague()" class="bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 px-20 py-6 rounded-3xl font-black text-2xl shadow-2xl hover:shadow-emerald-500/50 transform hover:-translate-y-2 transition-all duration-500">⚡ Join Competition</button>
            </div>
        </div>
    </section>

    <!-- Settings Panel -->
    <div id="settings-panel" class="glass fixed top-24 right-6 z-50 p-8 rounded-3xl shadow-2xl w-96 max-h-[80vh] overflow-y-auto hidden transform scale-95 transition-all duration-300">
        <h3 class="text-3xl font-black mb-8 gradient-text flex items-center gap-3">
            ⚙️ Smart Settings
            <button onclick="toggleSettings()" class="ml-auto text-xl hover:scale-110 transition-all duration-200">✕</button>
        </h3>
        
        <div class="space-y-6">
            <div>
                <label class="block font-semibold mb-3 text-lg">Class/Level</label>
                <select class="w-full bg-gray-900/70 border border-white/20 hover:border-white/30 rounded-2xl px-6 py-4 text-lg transition-all duration-200">
                    <option>Class 12 (JEE Advanced)</option>
                    <option>Class 11</option>
                    <option>Class 10 (CBSE)</option>
                    <option>B.Tech Computer Science</option>
                    <option>MBA Entrance</option>
                </select>
            </div>
            <div>
                <label class="block font-semibold mb-3 text-lg">Exam</label>
                <select class="w-full bg-gray-900/70 border border-white/20 hover:border-white/30 rounded-2xl px-6 py-4 text-lg transition-all duration-200">
                    <option>JEE Advanced</option>
                    <option>JEE Main</option>
                    <option>NEET UG</option>
                    <option>SAT</option>
                    <option>ACT</option>
                </select>
            </div>
            <div>
                <label class="block font-semibold mb-3 text-lg">Subject</label>
                <select class="w-full bg-gray-900/70 border border-white/20 hover:border-white/30 rounded-2xl px-6 py-4 text-lg transition-all duration-200">
                    <option>Mathematics</option>
                    <option>Physics</option>
                    <option>Chemistry</option>
                    <option>AI/ML</option>
                    <option>Music Theory</option>
                </select>
            </div>
            <div>
                <label class="block font-semibold mb-3 text-lg">Language</label>
                <select class="w-full bg-gray-900/70 border border-white/20 hover:border-white/30 rounded-2xl px-6 py-4 text-lg transition-all duration-200">
                    <option selected>🇮🇳 Hindi</option>
                    <option>🇺🇸 English</option>
                    <option>🇧🇩 Bengali</option>
                    <option>🇪🇸 Spanish</option>
                    <option>🇫🇷 French</option>
                </select>
            </div>
        </div>
        
        <button onclick="toggleSettings()" class="mt-8 w-full bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 px-8 py-5 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-emerald-500/50 transform hover:-translate-y-1 transition-all duration-300">✅ Save Settings</button>
    </div>

    <script>
        // Global state
        let isVoiceActive = false;
        let userPoints = 0;

        // Smooth scroll functions
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function scrollToChat() {
            document.querySelector('#chat-messages').scrollIntoView({ behavior: 'smooth' });
        }

        // Settings panel
        function toggleSettings() {
            const panel = document.getElementById('settings-panel');
            panel.classList.toggle('hidden');
            panel.classList.toggle('scale-95');
        }

        // Chat functionality
        function sendMessage() {
            const input = document.getElementById('chat-input');
            const messages = document.getElementById('chat-messages');
            const message = input.value.trim();
            
            if (!message) return;

            // User message
            const userMsg = document.createElement('div');
            userMsg.className = 'bg-gradient-to-r from-blue-500/20 to-blue-600/20 backdrop-blur-sm p-6 rounded-2xl max-w-md ml-auto animate-pulse';
            userMsg.innerHTML = `<strong style="color: #60a5fa;">You:</strong> ${message}`;
            messages.appendChild(userMsg);
            
            // Clear input and scroll
            input.value = '';
            messages.scrollTop = messages.scrollHeight;
            
            // AI response after delay
            setTimeout(() => {
                const aiMsg = document.createElement('div');
                aiMsg.className = 'bg-white/10 backdrop-blur-sm p-6 rounded-2xl max-w-lg';
                aiMsg.innerHTML = `
                    <strong style="color: #34d399;">🤖 AI Tutor:</strong> Perfect JEE Advanced question! Here's the step-by-step solution:<br><br>
                    <div class="ml-6 mt-3 space-y-2">
                        <div><span class="text-emerald-400">1.</span> Integration by parts: <code class="bg-gray-800 px-2 py-1 rounded text-sm inline-block">u = x², dv = eˣdx</code></div>
                        <div><span class="text-emerald-400">2.</span> <code class="bg-gray-800 px-2 py-1 rounded text-sm inline-block">du = 2x dx, v = eˣ</code></div>
                        <div><span class="text-emerald-400">3.</span> Final: <code class="bg-gray-800 px-2 py-1 rounded text-sm inline-block">x²eˣ - 2xeˣ + 2eˣ + C</code> ✨</div>
                    </div>
                `;
                messages.appendChild(aiMsg);
                messages.scrollTop = messages.scrollHeight;
                userPoints += 25;
            }, 1200);
        }

        // Voice toggle
        function toggleVoice() {
            const btn = document.getElementById('voice-btn');
            
            if ('webkitSpeechRecognition' in window && !isVoiceActive) {
                const recognition = new (window.webkitSpeechRecognition || window.SpeechRecognition)();
                recognition.continuous = false;
                recognition.interimResults = false;
                
                recognition.onstart = () => {
                    isVoiceActive = true;
                    btn.innerHTML = '🔴';
                    btn.classList.add('animate-pulse');
                };
                
                recognition.onresult = (event) => {
                    const transcript = event.results[0][0].transcript;
                    document.getElementById('chat-input').value = transcript;
                    sendMessage();
                };
                
                recognition.onend = () => {
                    isVoiceActive = false;
                    btn.innerHTML = '🎤';
                    btn.classList.remove('animate-pulse');
                };
                
                recognition.start();
            } else {
                alert('Voice recognition not supported in this browser');
            }
        }

        // Camera simulation
        function simulateCamera() {
            alert('📷 Camera opened! (Mobile: tap allow camera access)\n\nDesktop simulation: Photo analysis complete!');
            document.getElementById('upload-result').classList.remove('hidden');
        }

        function openCamera() {
            const fileInput = document.getElementById('file-upload');
            fileInput.click();
        }

        // File upload handler
        document.getElementById('file-upload').addEventListener('change', function(e) {
            if (e.target.files.length > 0) {
                document.getElementById('upload-result').classList.remove('hidden');
            }
        });

        // Quick actions
        function joinLeague() {
            userPoints += 100;
            alert(`🏆 League joined!\n+100 points\nTotal: ${userPoints} pts\nClimb the ranks!`);
        }

        function startTest() {
            userPoints += 75;
            alert(`📊 Mock Test Complete!\n95% Score\n+75 points\nTotal: ${userPoints} pts`);
        }

        function claimRank(position) {
            alert(`🥇 Claiming #${position} rank!\nPractice more to beat Rahul S. (12,847 pts)`);
        }

        // PWA install
        function installPWA() {
            if (window.deferredPrompt) {
                window.deferredPrompt.prompt();
            } else {
                alert('Add to home screen via browser menu (⋮ → Install App)');
            }
        }

        // Event listeners
        document.getElementById('chat-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Initialize
        window.addEventListener('load', function() {
            // Add initial welcome message
            const welcomeMsg = document.createElement('div');
            welcomeMsg.className = 'bg-white/10 backdrop-blur-sm p-6 rounded-2xl max-w-lg text-center border-2 border-emerald-400/30';
            welcomeMsg.innerHTML = '<strong style="color: #34d399;">🤖 AI Tutor:</strong> नमस्ते! JEE Advanced Math के लिए तैयार हूँ। अपना पहला सवाल पूछें! ✨';
            document.getElementById('chat-messages').appendChild(welcomeMsg);
        });

        // Custom scrollbar
        const style = document.createElement('style');
        style.textContent = `
            .scrollbar-thin::-webkit-scrollbar { width: 6px; }
            .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
            .scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 3px; }
            .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.4); }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
